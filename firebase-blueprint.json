{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer or contact.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the lead."
        },
        "company": {
          "type": "string",
          "description": "The company the lead works for."
        },
        "status": {
          "type": "string",
          "enum": ["New", "Contacted", "Qualified", "Lost"],
          "description": "The current status of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created this lead."
        }
      },
      "required": ["name", "email", "status", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Stores leads created by users."
    }
  }
}
